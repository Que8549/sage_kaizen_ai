# Huggingface Token
HF_TOKEN=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

# Q5: try 96 → 112 → 128 → 160 (until load fails / VRAM is near limit)
# Q6: try 80 → 96 → 112 (Q6 generally needs more VRAM)
SAGE_KAIZEN_GPU_LAYERS_Q5=128
SAGE_KAIZEN_GPU_LAYERS_Q6=96

# Model Timeouts
q5_START_TIMEOUT_SECS=10800.0   # 3 hours
q6_START_TIMEOUT_SECS=10800.0   # 3 hours

# RagSettings
SAGE_RAG_ENABLED=1
SAGE_RAG_FAST_TOPK=4
SAGE_RAG_ARCH_TOPK=10

# Minimum relevance score to inject a chunk (0.0 = no filter, 1.0 = exact match only).
# Score = 1 / (1 + cosine_distance).  A value of ~0.40 filters out near-noise results.
# Set via env var SAGE_RAG_MIN_SCORE or .env file.
SAGE_RAG_MIN_SCORE=0.0

# Maximum cosine distance allowed in the SQL WHERE clause (pre-filters before Python).
# Cosine distance range: 0.0 (identical) → 2.0 (opposite).  0.5 ≈ score > 0.67.
# Set via env var SAGE_RAG_MAX_DISTANCE or .env file.
SAGE_RAG_MAX_DISTANCE=0.5

# Database
PG_USER=sage
PG_PASSWORD=Sage123
PG_DB=sage_kaizen
